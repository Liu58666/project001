# 复制本文件为 .env 并填入真实值。.env 已被 .gitignore 忽略，切勿提交。
# 所有密钥仅从此处注入，源码中不得写死。

# ================== 基础配置 ==================
ENVIRONMENT=development
DEBUG=false
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
AUTO_MIGRATE=false

# 宿主机直接运行后端时使用 127.0.0.1；Docker Compose 内部由 DOCKER_DATABASE_URL 覆盖为 mysql 主机名。
DATABASE_URL=mysql+pymysql://dail_app:dail_app_password@127.0.0.1:3306/auth_service
DOCKER_DATABASE_URL=mysql+pymysql://dail_app:dail_app_password@mysql:3306/auth_service

# ================== MySQL Compose 配置 ==================
MYSQL_DATABASE=auth_service
MYSQL_USER=dail_app
MYSQL_PASSWORD=dail_app_password
MYSQL_ROOT_PASSWORD=change-me-local-root-password

# ================== JWT配置 ==================
# 生产环境请用随机生成的强密钥，例如: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-to-a-random-secret-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# ================== 腾讯云短信配置 ==================
SMS_ENABLED=false
SMS_SECRET_ID=
SMS_SECRET_KEY=
SMS_SDK_APP_ID=
SMS_SIGN_NAME=
SMS_TEMPLATE_ID=
SMS_REGION=ap-guangzhou

# ================== 验证码逻辑配置 ==================
VERIFICATION_CODE_LENGTH=6
VERIFICATION_CODE_EXPIRE_MINUTES=5
VERIFICATION_CODE_RESEND_INTERVAL_SECONDS=60

# ================== 腾讯云COS配置 ==================
COS_ENABLED=false
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=ap-guangzhou
COS_BUCKET=
COS_DOMAIN=
