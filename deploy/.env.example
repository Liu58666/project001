# Copy this file to deploy/.env on the server and fill production values.
# Do not commit deploy/.env or real credentials.

# Public HTTP port exposed by the frontend Nginx container.
FRONTEND_HTTP_PORT=80

# Backend runtime.
ENVIRONMENT=production
DEBUG=false
AUTO_MIGRATE=false

# Set this to the real website origin used by browsers.
# Examples:
# CORS_ALLOWED_ORIGINS=https://example.com
# CORS_ALLOWED_ORIGINS=https://www.example.com,https://example.com
CORS_ALLOWED_ORIGINS=https://your-domain.example

# MySQL. Use strong production passwords.
MYSQL_DATABASE=auth_service
MYSQL_USER=dail_app
MYSQL_PASSWORD=replace-with-strong-db-password
MYSQL_ROOT_PASSWORD=replace-with-strong-root-password

# JWT. Generate with:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=replace-with-random-secret-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12

# Tencent Cloud SMS. Keep disabled unless credentials and template are ready.
SMS_ENABLED=false
SMS_SECRET_ID=
SMS_SECRET_KEY=
SMS_SDK_APP_ID=
SMS_SIGN_NAME=
SMS_TEMPLATE_ID=
SMS_REGION=ap-guangzhou

# Verification code behavior.
VERIFICATION_CODE_LENGTH=6
VERIFICATION_CODE_EXPIRE_MINUTES=5
VERIFICATION_CODE_RESEND_INTERVAL_SECONDS=60

# Tencent Cloud COS. Required for image/PDF upload features when COS_ENABLED=true.
COS_ENABLED=false
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=ap-guangzhou
COS_BUCKET=
COS_DOMAIN=
